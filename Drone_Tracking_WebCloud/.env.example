# ===== Drone Tracking WebCloud 环境变量 =====
# 复制本文件为 .env 后修改

# JWT 密钥（生产环境必须设置固定值，否则每次重启所有 token 失效）
JWT_SECRET=change-me-to-a-random-string-at-least-48-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# 数据库 URL（默认 SQLite，支持切换为 PostgreSQL 等）
DATABASE_URL=sqlite+aiosqlite:///./drone_tracking.db

# 初始管理员账户（仅首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
